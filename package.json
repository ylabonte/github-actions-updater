{
  "name": "github-actions-updater",
  "version": "0.0.0",
  "description": "ncu for GitHub Actions — scans .github/workflows for outdated remote uses: references and reports or updates them, with a polished colorful CLI.",
  "keywords": [
    "github-actions",
    "workflow",
    "updater",
    "ncu",
    "dependencies",
    "cli",
    "version-check",
    "actions"
  ],
  "license": "MIT",
  "author": "Yannic Labonte",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "bin": {
    "gau": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && chmod +x dist/cli.js",
    "dev": "tsx src/cli.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "docs:dev": "vitepress dev docs",
    "docs:build": "pnpm run docs:gen-cli && vitepress build docs",
    "docs:gen-cli": "tsx docs/scripts/gen-cli-ref.ts",
    "prepublishOnly": "pnpm run build",
    "release": "changeset publish"
  },
  "dependencies": {
    "@clack/prompts": "^0.11.0",
    "@commander-js/extra-typings": "^12.1.0",
    "@octokit/rest": "^21.0.2",
    "cli-table3": "^0.6.5",
    "commander": "^12.1.0",
    "cosmiconfig": "^9.0.0",
    "env-paths": "^3.0.0",
    "ora": "^8.1.1",
    "picocolors": "^1.1.1",
    "semver": "^7.6.3",
    "yaml": "^2.6.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.10",
    "@eslint/js": "^9.16.0",
    "@types/node": "^22.10.1",
    "@types/semver": "^7.5.8",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "@vitest/coverage-v8": "^2.1.8",
    "eslint": "^9.16.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-unicorn": "^56.0.1",
    "eslint-plugin-vitest": "^0.5.4",
    "memfs": "^4.15.1",
    "nock": "^14.0.0-beta.18",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0",
    "vitepress": "^1.5.0",
    "vitest": "^2.1.8"
  },
  "packageManager": "pnpm@9.15.0"
}
